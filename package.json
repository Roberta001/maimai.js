{
  "name": "maimai.js",
  "version": "1.0.5",
  "description": "maimai DX async API client ported from maimai.py",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Roberta001/maimai.js.git"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "keywords": [
    "maimai",
    "maimaidx"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.2.0",
    "lru-cache": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
